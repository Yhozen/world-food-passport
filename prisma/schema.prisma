generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id          String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String
  countryCode String    @map("country_code")
  countryName String    @map("country_name")
  city        String?
  address     String?
  website     String?
  googleMapsUrl String? @map("google_maps_url")
  latitude    Decimal?  @db.Decimal(10, 8)
  longitude   Decimal?  @db.Decimal(11, 8)
  cuisineTags String[]  @map("cuisine_tags")
  visitDate   DateTime? @map("visit_date") @db.Date
  rating      Int?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  reviews Review[]
  photos  Photo[]
  sharedVisit SharedVisit?

  @@map("restaurants")
}

model SharedVisit {
  id          String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  restaurantId String @unique @map("restaurant_id") @db.Uuid
  ownerUserId String   @map("owner_user_id") @db.Uuid
  shareCode   String   @unique @map("share_code")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  members    SharedVisitMember[]

  @@map("shared_visits")
}

model SharedVisitMember {
  id            String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  sharedVisitId String   @map("shared_visit_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  role          String   @default("member")
  joinedAt      DateTime @default(now()) @map("joined_at")

  sharedVisit SharedVisit @relation(fields: [sharedVisitId], references: [id], onDelete: Cascade)

  @@unique([sharedVisitId, userId])
  @@map("shared_visit_members")
}

model Review {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  content      String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, userId])
  @@map("reviews")
}

model Photo {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  storageUrl   String   @map("storage_url")
  caption      String?
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model CountriesVisited {
  id             String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  countryCode    String   @map("country_code")
  countryName    String   @map("country_name")
  visitCount     Int      @default(1) @map("visit_count")
  firstVisitedAt DateTime @default(now()) @map("first_visited_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([userId, countryCode])
  @@map("countries_visited")
}

model ChallengeProgress {
  id                   String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  challengeId          String    @map("challenge_id")
  enrolledAt           DateTime  @default(now()) @map("enrolled_at")
  unlockedCountryCodes String[]  @default([]) @map("unlocked_country_codes")
  uniqueTargetCount    Int       @default(0) @map("unique_target_count")
  completedAt          DateTime? @map("completed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@unique([userId, challengeId])
  @@map("challenge_progress")
}

model ChallengeAchievementUnlock {
  id             String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  challengeId    String   @map("challenge_id")
  achievementKey String   @map("achievement_key")
  unlockedAt     DateTime @default(now()) @map("unlocked_at")

  @@unique([userId, challengeId, achievementKey])
  @@map("challenge_achievement_unlocks")
}

model ChallengeRepairJob {
  id          String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  challengeId String   @map("challenge_id")
  reason      String
  status      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("challenge_repair_jobs")
}
